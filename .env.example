# Copy this file to .env and fill in your key:  cp .env.example .env
#
# This project loads ONLY its own .env (by explicit path), so it will not pick up
# a .env from a parent folder or another project. The .env file is gitignored.
#
# Needed only for the ADK engine (python -m demo.run --engine adk).
# The default heuristic demo needs no key at all.

# Default backend: Gemini (Google AI Studio key)
GOOGLE_API_KEY=your-gemini-key-here

# Alternative backend: Claude via LiteLLM.
# Swap MODEL in agents/adk_agents.py to the LiteLlm(...) line, then set:
# ANTHROPIC_API_KEY=your-anthropic-key-here
